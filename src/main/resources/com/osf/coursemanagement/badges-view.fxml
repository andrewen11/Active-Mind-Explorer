<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" styleClass="root-background" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.osf.coursemanagement.controller.BadgesController">

    <!-- TOP HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-container">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label styleClass="greeting-header" text="Badges &amp; Progress Manager" />
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <SplitPane dividerPositions="0.35" style="-fx-background-color: transparent;">
            <BorderPane.margin>
                <Insets bottom="0" left="0" right="0" top="20" />
            </BorderPane.margin>
            <items>

                <!-- LEFT PANEL: Selection -->
                <VBox spacing="15.0" styleClass="sidebar-section">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10" />
                    </padding>

                    <Label styleClass="field-label" text="Select Course:" />
                    <ComboBox styleClass="combo-box" fx:id="comboCourses" maxWidth="Infinity" promptText="Select a course..." />

                    <Label styleClass="field-label" text="Students (Trainees):" />
                    <ListView fx:id="listTrainees" styleClass="custom-list-view" VBox.vgrow="ALWAYS" />

                    <HBox spacing="10" alignment="CENTER">
                         <Button fx:id="btnAddStudent" text="Add Student" onAction="#handleAddStudent" styleClass="outline-button" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                         <Button fx:id="btnRemoveStudent" text="Remove" onAction="#handleRemoveStudent" styleClass="outline-button" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- RIGHT PANEL: Details -->
                <StackPane styleClass="detail-panel-container">

                    <!-- Content View -->
                    <VBox fx:id="detailsContainer" alignment="TOP_LEFT" spacing="15.0" visible="false">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20" />
                        </padding>

                        <!-- Header Info -->
                        <HBox spacing="20" alignment="CENTER_LEFT">

                             <VBox>
                                 <Label fx:id="lblTraineeName" styleClass="title_label" text="Student Name" />
                                 <Label fx:id="lblTotalBadges" text="Total Badges: 0" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                                 <Label fx:id="lblTotalScore" text="Total Score for Course: 0" style="-fx-font-size: 12px;"/>
                             </VBox>
                        </HBox>

                        <Label styleClass="field_label2" text="Module Progress:" />

                        <!-- Scrollable Module List -->
                        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;" VBox.vgrow="ALWAYS">
                             <content>
                                 <VBox fx:id="modulesContainer" spacing="10">
                                     <!-- Dynamic Module Rows will be added here -->
                                 </VBox>
                             </content>
                        </ScrollPane>

                        <Button fx:id="btnSaveProgress" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleSaveProgress" styleClass="action-button" text="Save Progress" />
                    </VBox>

                    <!-- Placeholder View -->
                    <Label fx:id="lblPlaceholder" alignment="CENTER" text="Select a student to manage badges" textFill="#7f8c8d">
                        <font>
                            <Font size="16.0" />
                        </font>
                    </Label>
                </StackPane>
            </items>
        </SplitPane>
    </center>

    <!-- BOTTOM FOOTER -->
    <bottom>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="20" VBox.vgrow="NEVER">
                 <Button onAction="#handleBack" styleClass="action-button" text="← Back to Dashboard" />
                 <Region HBox.hgrow="ALWAYS" />
                 <Button fx:id="btnThemeToggle" onAction="#handleThemeToggle" styleClass="action-button" text="Light / Dark Mode" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
